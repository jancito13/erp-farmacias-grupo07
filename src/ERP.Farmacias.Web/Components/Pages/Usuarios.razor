@page "/usuarios"
@attribute [Authorize(Roles = "Administrador")]
@using Microsoft.AspNetCore.Authorization

@inject IUsuarioService UsuarioService
@inject RoleManager<ApplicationRole> RoleManager
@inject ISnackbar Snackbar
@inject IDialogService DialogService

<PageTitle>Usuarios</PageTitle>

<AuthorizeView Roles="Administrador">
    <Authorized Context="authContext">
        <MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-4">
            <MudText Typo="Typo.h5">Gestión de Usuarios</MudText>
            <MudSpacer />
            <MudButton Variant="Variant.Filled"
                       Color="Color.Primary"
                       StartIcon="@Icons.Material.Filled.PersonAdd"
                       OnClick="AbrirNuevoUsuario">
                Nuevo usuario
            </MudButton>
        </MudStack>

        <MudDataGrid T="UsuarioResponseDto" Items="_usuarios"
                     Filterable="true" SortMode="SortMode.Multiple"
                     Striped="true" Hover="true" Bordered="true">
            <Columns>
                <PropertyColumn Property="u => u.FullName" Title="Nombre completo" />
                <PropertyColumn Property="u => u.Email" Title="Email" />
                <PropertyColumn Property="u => u.RoleName" Title="Rol" />
                <TemplateColumn Title="Estado" Sortable="false" Filterable="false">
                    <CellTemplate>
                        <MudChip T="string"
                                 Color="@(context.Item.IsActive ? Color.Success : Color.Error)"
                                 Size="Size.Small"
                                 Variant="Variant.Filled">
                            @(context.Item.IsActive ? "Activo" : "Inactivo")
                        </MudChip>
                    </CellTemplate>
                </TemplateColumn>
                <TemplateColumn Title="Acciones" Sortable="false" Filterable="false">
                    <CellTemplate>
                        <MudTooltip Text="Editar">
                            <MudIconButton Icon="@Icons.Material.Filled.Edit"
                                           Color="Color.Info"
                                           Size="Size.Small"
                                           OnClick="@(() => AbrirEditar(context.Item))" />
                        </MudTooltip>
                        <MudTooltip Text="@(context.Item.IsActive ? "Desactivar" : "Activar")">
                            <MudIconButton
                                Icon="@(context.Item.IsActive ? Icons.Material.Filled.PersonOff : Icons.Material.Filled.PersonAdd)"
                                Color="@(context.Item.IsActive ? Color.Warning : Color.Success)"
                                Size="Size.Small"
                                OnClick="@(() => ConfirmarToggle(context.Item))" />
                        </MudTooltip>
                    </CellTemplate>
                </TemplateColumn>
            </Columns>
        </MudDataGrid>
    </Authorized>
    <NotAuthorized>
        <MudPaper Class="pa-8 ma-4" Elevation="2">
            <MudStack AlignItems="AlignItems.Center" Spacing="4">
                <MudIcon Icon="@Icons.Material.Filled.Lock" Color="Color.Error" Style="font-size: 4rem;" />
                <MudText Typo="Typo.h5" Color="Color.Error">Acceso denegado</MudText>
                <MudText Typo="Typo.body1" Align="Align.Center">
                    No tienes permisos para acceder a esta sección.
                    Solo los usuarios con el rol <strong>Administrador</strong> pueden gestionar usuarios.
                </MudText>
                <MudButton Variant="Variant.Filled"
                           Color="Color.Primary"
                           Href="/"
                           StartIcon="@Icons.Material.Filled.Home">
                    Volver al inicio
                </MudButton>
            </MudStack>
        </MudPaper>
    </NotAuthorized>
</AuthorizeView>

@code {
    private List<UsuarioResponseDto> _usuarios = [];
    private List<string> _roles = [];

    protected override async Task OnInitializedAsync()
    {
        await CargarUsuarios();
        _roles = RoleManager.Roles.Select(r => r.Name!).OrderBy(r => r).ToList();
    }

    private async Task CargarUsuarios()
    {
        _usuarios = await UsuarioService.GetAllAsync();
    }

    private async Task AbrirNuevoUsuario()
    {
        var parameters = new DialogParameters<UsuarioFormDialog>
        {
            { x => x.EditandoId, null },
            { x => x.Form, new() },
            { x => x.Roles, _roles }
        };
        var dialog = await DialogService.ShowAsync<UsuarioFormDialog>("Nuevo usuario", parameters,
            new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true, CloseOnEscapeKey = true });
        var result = await dialog.Result;
        if (result is { Canceled: false })
            await CargarUsuarios();
    }

    private async Task AbrirEditar(UsuarioResponseDto usuario)
    {
        var parameters = new DialogParameters<UsuarioFormDialog>
        {
            { x => x.EditandoId, usuario.Id },
            { x => x.Form, new() { FullName = usuario.FullName, Email = usuario.Email, RoleName = usuario.RoleName } },
            { x => x.Roles, _roles }
        };
        var dialog = await DialogService.ShowAsync<UsuarioFormDialog>("Editar usuario", parameters,
            new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true, CloseOnEscapeKey = true });
        var result = await dialog.Result;
        if (result is { Canceled: false })
            await CargarUsuarios();
    }

    private async Task ConfirmarToggle(UsuarioResponseDto usuario)
    {
        var msgBox = new DialogParameters<MudMessageBox>
        {
            { x => x.Message, "¿Confirmas cambiar el estado de este usuario?" },
            { x => x.YesText, "Confirmar" },
            { x => x.CancelText, "Cancelar" }
        };
        var dialog = await DialogService.ShowAsync<MudMessageBox>("Confirmar acción", msgBox);
        var result = await dialog.Result;
        if (result.Canceled) return;

        bool ok = await UsuarioService.ToggleActiveAsync(usuario.Id);
        if (ok)
        {
            usuario.IsActive = !usuario.IsActive;
            StateHasChanged();
        }
        else
        {
            Snackbar.Add("No se pudo cambiar el estado.", Severity.Error);
        }
    }
}
