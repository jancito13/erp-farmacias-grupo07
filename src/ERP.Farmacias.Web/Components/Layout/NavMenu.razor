<AuthorizeView>
    <Authorized>
        <MudNavMenu>

            @* Dashboard: visible para todos los roles *@
            <MudNavLink Href="/"
                        Match="NavLinkMatch.All"
                        Icon="@Icons.Material.Filled.Dashboard">
                Dashboard
            </MudNavLink>

            @* Administración: solo Administrador *@
            <AuthorizeView Roles="Administrador" Context="_adminCtx">
                <Authorized>
                    <MudNavGroup Title="Administración"
                                 Icon="@Icons.Material.Filled.AdminPanelSettings"
                                 Expanded="true">
                        <MudNavLink Href="/usuarios"
                                    Icon="@Icons.Material.Filled.People">
                            Usuarios
                        </MudNavLink>
                        <MudNavLink Href="/auditoria"
                                    Icon="@Icons.Material.Filled.Security">
                            Log de Auditoría
                        </MudNavLink>
                    </MudNavGroup>
                </Authorized>
            </AuthorizeView>

            @* Caja & Ventas: Cajero, Administrador, Gerente *@
            <AuthorizeView Roles="Cajero,Administrador,Gerente" Context="_cajaCtx">
                <Authorized>
                    <MudNavGroup Title="Caja &amp; Ventas"
                                 Icon="@Icons.Material.Filled.PointOfSale"
                                 Expanded="false">
                        <MudNavLink Href="/caja"
                                    Icon="@Icons.Material.Filled.ShoppingCart">
                            Punto de venta
                        </MudNavLink>
                    </MudNavGroup>
                </Authorized>
            </AuthorizeView>

            @* Inventario: Almacenero, Administrador, Gerente *@
            <AuthorizeView Roles="Almacenero,Administrador,Gerente" Context="_almacenCtx">
                <Authorized>
                    <MudNavGroup Title="Inventario"
                                 Icon="@Icons.Material.Filled.Inventory"
                                 Expanded="false">
                        <MudNavLink Href="/inventario"
                                    Icon="@Icons.Material.Filled.Storage">
                            Productos
                        </MudNavLink>
                    </MudNavGroup>
                </Authorized>
            </AuthorizeView>

            @* Compras: JefeCompras, Administrador, Gerente *@
            <AuthorizeView Roles="JefeCompras,Administrador,Gerente" Context="_comprasCtx">
                <Authorized>
                    <MudNavGroup Title="Compras"
                                 Icon="@Icons.Material.Filled.ShoppingBag"
                                 Expanded="false">
                        <MudNavLink Href="/compras"
                                    Icon="@Icons.Material.Filled.AddShoppingCart">
                            Órdenes de compra
                        </MudNavLink>
                    </MudNavGroup>
                </Authorized>
            </AuthorizeView>

            @* Contabilidad: Contador, Administrador, Gerente — NO Cajero *@
            <AuthorizeView Roles="Contador,Administrador,Gerente" Context="_contCtx">
                <Authorized>
                    <MudNavGroup Title="Contabilidad"
                                 Icon="@Icons.Material.Filled.AccountBalance"
                                 Expanded="false">
                        <MudNavLink Href="/contabilidad"
                                    Icon="@Icons.Material.Filled.ReceiptLong">
                            Reportes financieros
                        </MudNavLink>
                    </MudNavGroup>
                </Authorized>
            </AuthorizeView>

            @* RRHH: RRHH, Administrador, Gerente *@
            <AuthorizeView Roles="RRHH,Administrador,Gerente" Context="_rrhhCtx">
                <Authorized>
                    <MudNavGroup Title="RRHH"
                                 Icon="@Icons.Material.Filled.Badge"
                                 Expanded="false">
                        <MudNavLink Href="/rrhh"
                                    Icon="@Icons.Material.Filled.Group">
                            Personal
                        </MudNavLink>
                    </MudNavGroup>
                </Authorized>
            </AuthorizeView>

        </MudNavMenu>
    </Authorized>
    <NotAuthorized>
        <MudText Class="pa-4" Typo="Typo.body2">
            Inicia sesión para ver el menú.
        </MudText>
    </NotAuthorized>
</AuthorizeView>
