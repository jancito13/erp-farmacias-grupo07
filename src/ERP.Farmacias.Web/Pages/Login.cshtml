@page
@model ERP.Farmacias.Web.Pages.LoginModel
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Iniciar sesión — ERP Farmacias</title>
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Roboto:wght@300;400;500;700&display=swap" />
    <style>
        * { box-sizing: border-box; margin: 0; padding: 0; }
        body {
            font-family: 'Roboto', sans-serif;
            background: #f5f5f5;
            display: flex;
            align-items: center;
            justify-content: center;
            min-height: 100vh;
        }
        .card {
            background: #fff;
            border-radius: 8px;
            box-shadow: 0 2px 12px rgba(0,0,0,.12);
            padding: 2.5rem 2rem;
            width: 100%;
            max-width: 380px;
        }
        h1 { font-size: 1.4rem; font-weight: 500; color: #1976d2; margin-bottom: .25rem; }
        .subtitle { font-size: .875rem; color: #757575; margin-bottom: 1.75rem; }
        .form-group { margin-bottom: 1.25rem; }
        label { display: block; font-size: .8rem; color: #555; margin-bottom: .35rem; }
        input[type=email], input[type=password] {
            width: 100%; padding: .65rem .8rem;
            border: 1px solid #bdbdbd; border-radius: 4px;
            font-size: .95rem; outline: none; transition: border .2s;
        }
        input:focus { border-color: #1976d2; }
        .error {
            background: #ffebee; border-left: 4px solid #f44336;
            color: #c62828; padding: .6rem .8rem;
            border-radius: 4px; font-size: .85rem; margin-bottom: 1rem;
        }
        .btn-submit {
            width: 100%; padding: .75rem;
            background: #1976d2; color: #fff;
            border: none; border-radius: 4px;
            font-size: 1rem; font-weight: 500;
            cursor: pointer; transition: background .2s;
            display: flex; align-items: center; justify-content: center; gap: .5rem;
            min-height: 44px;
        }
        .btn-submit:hover:not(:disabled) { background: #1565c0; }
        .btn-submit:disabled { background: #90caf9; cursor: not-allowed; }

        /* MudProgressCircular equivalent */
        .mud-circular {
            display: none;
            width: 20px; height: 20px;
            border: 2.5px solid rgba(255,255,255,.35);
            border-top-color: #fff;
            border-radius: 50%;
            animation: mud-spin .7s linear infinite;
        }
        .loading .mud-circular { display: inline-block; }
        .loading .btn-text { display: none; }

        @@keyframes mud-spin {
            to { transform: rotate(360deg); }
        }
    </style>
</head>
<body>
    <div class="card">
        <h1>ERP Farmacias</h1>
        <p class="subtitle">Ingresa tus credenciales para continuar</p>

        @if (!string.IsNullOrEmpty(Model.ErrorMessage))
        {
            <div class="error">@Model.ErrorMessage</div>
        }

        <form method="post" id="loginForm">
            @Html.AntiForgeryToken()
            <div class="form-group">
                <label for="email">Correo electrónico</label>
                <input type="email" id="email" name="Email" value="@Model.Email" required autofocus />
            </div>
            <div class="form-group">
                <label for="password">Contraseña</label>
                <input type="password" id="password" name="Password" required />
            </div>
            <button type="submit" class="btn-submit" id="submitBtn">
                <span class="mud-circular"></span>
                <span class="btn-text">Iniciar sesión</span>
            </button>
        </form>
    </div>

    <script>
        document.getElementById('loginForm').addEventListener('submit', function () {
            var btn = document.getElementById('submitBtn');
            btn.disabled = true;
            btn.classList.add('loading');
        });
    </script>
</body>
</html>
